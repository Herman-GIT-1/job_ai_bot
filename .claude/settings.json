{
  "permissions": {
    "allow": [
      "Bash(git rm:*)",
      "Bash(git -C:*)",
      "Bash(python -c:*)",
      "Bash(python -c ':*)",
      "Bash(ls c:/Users/job_ai_bot/*)",
      "WebFetch(domain:www.sonara.ai)",
      "WebFetch(domain:apify.com)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/pre-commit-check.sh"
          }
        ]
      }
    ]
  }
}
